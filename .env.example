# ============================================================
# ChefControl — Variables de entorno (ejemplo)
# ============================================================
# Copia este archivo como .env y completa cada valor.
# NUNCA subas el archivo .env real al repositorio.
#
#   cp .env.example .env        (Linux / Mac)
#   copy .env.example .env      (Windows)
# ============================================================

# ----------------------------------------------------------
# Django
# ----------------------------------------------------------
# Clave secreta única y larga. Genera una nueva con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-unica

# True en desarrollo local, False en producción
DEBUG=True

# Hosts permitidos separados por coma (sin espacios)
# Producción: agrega tu dominio, ej. chefcontrol.com,www.chefcontrol.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ----------------------------------------------------------
# Base de datos MySQL
# ----------------------------------------------------------
DB_NAME=chefcontrol_db
DB_USER=root
DB_PASSWORD=tu-contraseña-de-mysql
DB_HOST=127.0.0.1
DB_PORT=3306